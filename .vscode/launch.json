{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run MCQ Platform",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": ["runserver", "--settings=mcqplatform.settings_dev"],
      "django": true,
      "justMyCode": true,
      "env": {
        "DJANGO_SETTINGS_MODULE": "mcqplatform.settings_dev"
      }
    }
  ]
}
